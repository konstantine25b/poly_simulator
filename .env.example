GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
CLOB_API_BASE_URL=https://clob.polymarket.com

LOG_LEVEL=INFO
REQUEST_TIMEOUT=10

# ── Database ──────────────────────────────────────────────────
# Choose "sqlite" (default, no setup needed) or "postgres"
DB_BACKEND=sqlite

# SQLite — path to the local database file
SQLITE_PATH=data/markets.db

# PostgreSQL — only needed when DB_BACKEND=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=poly_simulator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

JWT_SECRET=generate_a_long_random_string_and_set_here
ACCESS_TOKEN_TTL_SECONDS=86400

# Optional: POST /markets/refresh accepts header X-Refresh-Api-Key with this value (no JWT).
REFRESH_API_KEY=

# Bootstrap admin: used when users table is empty, and on each startup this email is admin with this password.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
